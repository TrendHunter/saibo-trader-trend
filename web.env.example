# Web dashboard env (VPS: /opt/polymarket-bot/web.env)
# Bot strategy/wallet stays in .env — do not duplicate private keys here.

# Login (required)
AUTH_USERNAME=admin
AUTH_PASSWORD=change-me-strong-password

# Public URL users open in browser (must match how you access the site)
NEXTAUTH_URL=http://YOUR_SERVER_IP:3001

# Auto-generated on first server_start_web.sh if unset; keep stable after first boot
# NEXTAUTH_SECRET=

# Bot bridge (localhost only on VPS — frontend proxies via server-side routes)
BOT_WS_URL=ws://127.0.0.1:8080
BOT_API_URL=http://127.0.0.1:8081

# Optional: must match BOT_API_TOKEN in .env if set
# BOT_API_TOKEN=

PORT=3001
DATABASE_URL=file:./prisma/data/dev.db

# IP guard (optional; used by frontend auth routes)
# IP_SECURITY_PATH=/opt/polymarket-bot/logs/ip_security.json
# APPLY_FIREWALL_BLOCK=true
